# DirectDrop Fastlane
# Kullanım: cd fastlane && bundle exec fastlane [platform] [lane]

def project_root
  File.expand_path("..", __dir__)
end

def pubspec_version_name
  pubspec = File.read(File.join(project_root, "pubspec.yaml"))
  if pubspec =~ /^version:\s*([^\+\s]+)/
    return Regexp.last_match(1)
  end
  UI.user_error!("pubspec.yaml içinde version bulunamadı")
end

# App Store'da yayınlamak istediğimiz diller. tr = birincil dil.
DIRECTDROP_APP_STORE_LOCALES = %w[tr en-US].freeze

def directdrop_meta(locale, file)
  path = File.join(project_root, "fastlane", "metadata", locale, "#{file}.txt")
  return nil unless File.exist?(path)
  content = File.read(path).strip
  content.empty? ? nil : content
end

def directdrop_connect_token
  require "spaceship"
  %w[APPSTORE_KEY_ID APPSTORE_ISSUER_ID APPSTORE_PRIVATE_KEY].each do |var|
    UI.user_error!("#{var} tanımlı değil") if ENV[var].to_s.empty?
  end
  token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV["APPSTORE_KEY_ID"],
    issuer_id: ENV["APPSTORE_ISSUER_ID"],
    key: ENV["APPSTORE_PRIVATE_KEY"]
  )
  Spaceship::ConnectAPI.token = token
  token
end

default_platform(:android)

# App Store Connect sometimes returns "No data" while Fastlane tries to
# inspect first-version review attachments that do not exist yet. That should
# not block metadata/screenshot uploads, so skip only this optional cleanup.
begin
  require "deliver/upload_metadata"

  if defined?(::Deliver::UploadMetadata) && (
    ::Deliver::UploadMetadata.instance_methods.include?(:review_attachment_file) ||
    ::Deliver::UploadMetadata.private_instance_methods.include?(:review_attachment_file)
  )
    ::Deliver::UploadMetadata.class_eval do
      alias_method :directdrop_original_review_attachment_file, :review_attachment_file unless method_defined?(:directdrop_original_review_attachment_file)

      define_method(:review_attachment_file) do |version|
        directdrop_original_review_attachment_file(version)
      rescue => error
        UI.important("Review attachment kontrolü atlandı: #{error.message}")
      end

      private :review_attachment_file
    end
  else
    UI.important("Deliver review_attachment_file patch uygulanmadı; hedef metod bulunamadı.")
  end
rescue LoadError
  UI.important("Deliver metadata patch yüklenemedi; Fastlane varsayılan akışla devam edecek.")
end

platform :android do
  desc "Release AAB derle (Flutter)"
  lane :build do
    Dir.chdir(project_root) do
      sh("flutter pub get")
      sh("flutter build appbundle --release")
    end
  end

  desc "Play Store internal track'e AAB yükle"
  lane :deploy do
    aab_path = File.join(project_root, "build/app/outputs/bundle/release/app-release.aab")
    build unless File.exist?(aab_path)

    json_key = ENV["PLAY_STORE_JSON_PATH"]
    UI.user_error!("PLAY_STORE_JSON_PATH tanımlı değil (.env veya export)") if json_key.nil? || json_key.empty?
    UI.user_error!("JSON dosyası yok: #{json_key}") unless File.exist?(json_key)

    # Üretim (production) track'ine ilk kez API ile tam yayın yapılamaz: Google
    # "Precondition check failed" döndürür. İlk production sürümü taslak (draft)
    # olarak yüklenir, sonra Play Console'da tek tıkla yayına alınır. Bu yüzden
    # release_status dışarıdan ayarlanabilir.
    release_status = ENV.fetch("PLAY_RELEASE_STATUS", "completed")

    upload_to_play_store(
      track: ENV.fetch("PLAY_STORE_TRACK", "internal"),
      aab: aab_path,
      json_key: json_key,
      package_name: "com.directdrop.app",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: release_status
    )
  end

  desc "Play Store ekran görüntüleri yükle"
  lane :screenshots do
    json_key = ENV["PLAY_STORE_JSON_PATH"]
    UI.user_error!("PLAY_STORE_JSON_PATH tanımlı değil") if json_key.nil? || json_key.empty?
    UI.user_error!("JSON dosyası yok: #{json_key}") unless File.exist?(json_key)

    upload_to_play_store(
      track: ENV.fetch("PLAY_STORE_TRACK", "internal"),
      json_key: json_key,
      package_name: "com.directdrop.app",
      metadata_path: "./metadata/android",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: false,
      release_status: "draft"
    )
  end
end

platform :ios do
  private_lane :app_store_api_key_from_env do
    UI.user_error!("APPSTORE_KEY_ID tanımlı değil") if ENV["APPSTORE_KEY_ID"].to_s.empty?
    UI.user_error!("APPSTORE_ISSUER_ID tanımlı değil") if ENV["APPSTORE_ISSUER_ID"].to_s.empty?
    UI.user_error!("APPSTORE_PRIVATE_KEY tanımlı değil") if ENV["APPSTORE_PRIVATE_KEY"].to_s.empty?

    app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_PRIVATE_KEY"],
      is_key_content_base64: false
    )
  end

  desc "Release IPA derle (Flutter)"
  lane :build do
    export_plist = File.join(project_root, "ios/ExportOptions.plist")
    UI.user_error!("ExportOptions.plist bulunamadı") unless File.exist?(export_plist)

    Dir.chdir(project_root) do
      sh("flutter pub get")
      sh("cd ios && pod install")
      sh("flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")
    end
  end

  desc "App Store Connect'e IPA yükle (TestFlight / review)"
  lane :deploy do
    ipa_dir = File.join(project_root, "build/ios/ipa")
    ipa_files = Dir[File.join(ipa_dir, "*.ipa")]
    if ipa_files.empty?
      build
      ipa_files = Dir[File.join(ipa_dir, "*.ipa")]
    end
    UI.user_error!("IPA bulunamadı: #{ipa_dir}") if ipa_files.empty?
    ipa_path = ipa_files.first
    UI.message("IPA yükleniyor: #{ipa_path}")

    upload_to_app_store(
      api_key: app_store_api_key_from_env,
      ipa: ipa_path,
      skip_metadata: true,
      skip_screenshots: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: ENV.fetch("SUBMIT_FOR_REVIEW", "false") == "true",
      automatic_release: false,
      force: true
    )
  end

  desc "App Store sürümünün locale'lerini ve whatsNew/description durumunu yazdır"
  lane :diagnose_locales do
    directdrop_connect_token
    app = Spaceship::ConnectAPI::App.find("com.directdrop.app")
    UI.user_error!("App bulunamadı: com.directdrop.app") if app.nil?
    UI.message("App primaryLocale: #{app.primary_locale}")
    version = app.get_edit_app_store_version(platform: "IOS")
    if version.nil?
      UI.important("Düzenlenebilir (edit) sürüm bulunamadı.")
      next
    end
    UI.message("Edit sürüm: #{version.version_string} (state=#{version.app_store_state})")
    locs = version.get_app_store_version_localizations
    UI.message("Sürüm localization sayısı: #{locs.size}")
    locs.each do |l|
      UI.message(
        "LOCALE=#{l.locale} | whatsNew=#{l.whats_new.to_s.length} chars | " \
        "description=#{l.description.to_s.length} chars | keywords=#{l.keywords.to_s.length}"
      )
    end
  end

  # En-US ekranlarını tr'den kopyala (App Store her localization için ayrı
  # ekran görüntüsü ister; metin içermediklerinden tr setini İngilizce için de
  # kullanabiliriz).
  desc "tr ekran görüntülerini en-US'a kopyala"
  lane :mirror_screenshots do
    require "fileutils"
    src = File.join(project_root, "fastlane", "screenshots", "tr")
    dst = File.join(project_root, "fastlane", "screenshots", "en-US")
    next UI.important("tr ekran görüntüsü klasörü yok, atlanıyor.") unless Dir.exist?(src)
    FileUtils.mkdir_p(dst)
    Dir.glob(File.join(src, "*.png")).each do |f|
      FileUtils.cp(f, File.join(dst, File.basename(f)))
    end
    UI.success("en-US ekran görüntüleri hazırlandı (#{Dir.glob(File.join(dst, '*.png')).size} dosya)")
  end

  # Spaceship ile App Store sürüm + uygulama bilgisi localization'larını
  # oluştur/güncelle. deliver yalnızca var olan locale'leri güncellediğinden ve
  # whatsNew'i (ilk sürüm varsayımıyla) atladığından bunu doğrudan yapıyoruz.
  desc "App Store tr + en-US localization'larını oluştur/güncelle (whatsNew dahil)"
  lane :ensure_localizations do
    directdrop_connect_token
    app = Spaceship::ConnectAPI::App.find("com.directdrop.app")
    UI.user_error!("App bulunamadı: com.directdrop.app") if app.nil?

    version = app.get_edit_app_store_version(platform: "IOS")
    UI.user_error!("Düzenlenebilir (edit) sürüm yok.") if version.nil?

    existing_version_locs = version.get_app_store_version_localizations.each_with_object({}) do |l, h|
      h[l.locale] = l
    end

    DIRECTDROP_APP_STORE_LOCALES.each do |locale|
      desc_txt  = directdrop_meta(locale, "description")
      keywords  = directdrop_meta(locale, "keywords")
      whats_new = directdrop_meta(locale, "release_notes")
      promo     = directdrop_meta(locale, "promotional_text")
      support   = directdrop_meta(locale, "support_url")
      marketing = directdrop_meta(locale, "marketing_url")

      if (loc = existing_version_locs[locale])
        loc.update(attributes: {
          description: desc_txt,
          keywords: keywords,
          whats_new: whats_new,
          promotional_text: promo,
          support_url: support,
          marketing_url: marketing
        }.compact)
        UI.success("Sürüm localization güncellendi: #{locale} (whatsNew #{whats_new.to_s.length} chars)")
      else
        version.create_app_store_version_localization(attributes: {
          "locale" => locale,
          "description" => desc_txt,
          "keywords" => keywords,
          "whatsNew" => whats_new,
          "promotionalText" => promo,
          "supportUrl" => support,
          "marketingUrl" => marketing
        }.compact)
        UI.success("Sürüm localization OLUŞTURULDU: #{locale}")
      end
    end

    # Uygulama bilgisi (App Info) localization'ları: ad, alt başlık, gizlilik URL.
    app_info = app.fetch_edit_app_info
    if app_info.nil?
      UI.important("Düzenlenebilir App Info yok; ad/alt başlık güncellenmedi.")
    else
      existing_info_locs = app_info.get_app_info_localizations.each_with_object({}) do |l, h|
        h[l.locale] = l
      end

      DIRECTDROP_APP_STORE_LOCALES.each do |locale|
        name        = directdrop_meta(locale, "name")
        subtitle    = directdrop_meta(locale, "subtitle")
        privacy_url = directdrop_meta(locale, "privacy_url")

        if (loc = existing_info_locs[locale])
          loc.update(attributes: {
            name: name,
            subtitle: subtitle,
            privacy_policy_url: privacy_url
          }.compact)
          UI.success("App Info localization güncellendi: #{locale}")
        else
          app_info.create_app_info_localization(attributes: {
            "locale" => locale,
            "name" => name,
            "subtitle" => subtitle,
            "privacyPolicyUrl" => privacy_url
          }.compact)
          UI.success("App Info localization OLUŞTURULDU: #{locale}")
        end
      end
    end
  end

  desc "Yüklenmiş (işlenmiş) build'i App Store incelemesine gönder — yeniden derleme yok (tr + en-US)"
  lane :submit_review do
    # 1) İngilizce ekran görüntülerini hazırla (tr'den kopyala).
    mirror_screenshots

    # 2) tr + en-US localization'larını spaceship ile oluştur/güncelle (whatsNew dahil).
    #    deliver whatsNew'i atladığı ve yeni locale oluşturmadığı için bunu doğrudan yapıyoruz.
    ensure_localizations

    diagnose_locales

    # 3) Ekran görüntülerini yükle (artık en-US localization da var). Metin metadata'sına
    #    dokunma (skip_metadata) ki spaceship ile yazdığımız whatsNew korunsun.
    upload_to_app_store(
      api_key: app_store_api_key_from_env,
      app_identifier: "com.directdrop.app",
      app_version: pubspec_version_name,
      metadata_path: "./metadata",
      screenshots_path: "./screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      ignore_language_directory_validation: true,
      force: true
    )

    # 4) İncelemeye gönder (metadata/ekran görüntüsüne dokunmadan).
    upload_to_app_store(
      api_key: app_store_api_key_from_env,
      app_identifier: "com.directdrop.app",
      app_version: pubspec_version_name,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true
    )
  end

  desc "App Store Connect metadata ve screenshot yükle"
  lane :metadata do
    upload_to_app_store(
      api_key: app_store_api_key_from_env,
      app_identifier: "com.directdrop.app",
      app_version: pubspec_version_name,
      metadata_path: "./metadata",
      screenshots_path: "./screenshots",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      force: true
    )
  end

  desc "App Store Connect metin alanları (ekran görüntüsü dokunulmaz)"
  lane :metadata_text do
    upload_to_app_store(
      api_key: app_store_api_key_from_env,
      app_identifier: "com.directdrop.app",
      app_version: pubspec_version_name,
      metadata_path: "./metadata",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      ignore_language_directory_validation: true,
      force: true
    )
  end
end
