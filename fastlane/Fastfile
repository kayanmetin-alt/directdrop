default_platform(:android)

platform :android do
  desc "Play Store internal track'e AAB yükle"
  lane :deploy do
    aab_path = "../build/app/outputs/bundle/release/app-release.aab"
    unless File.exist?(aab_path)
      UI.user_error!("AAB bulunamadı: #{aab_path}. Önce flutter build appbundle çalıştırın.")
    end

    json_key = ENV["PLAY_STORE_JSON_PATH"]
    UI.user_error!("PLAY_STORE_JSON_PATH tanımlı değil") if json_key.nil? || json_key.empty?

    upload_to_play_store(
      track: ENV.fetch("PLAY_STORE_TRACK", "internal"),
      aab: aab_path,
      json_key: json_key,
      package_name: "com.directdrop.app",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed"
    )
  end
end

platform :ios do
  desc "App Store Connect'e IPA yükle (TestFlight / review)"
  lane :deploy do
    ipa_files = Dir["../build/ios/ipa/*.ipa"]
    UI.user_error!("IPA bulunamadı") if ipa_files.empty?
    ipa_path = ipa_files.first

    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: ipa_path,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end
end
