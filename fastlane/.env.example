# fastlane/.env — bu dosyayı kopyalayın: cp .env.example .env
# .env git'e eklenmez; gizli anahtarlar burada kalır.

# Apple hesabı (match için)
APPLE_ID=your-apple-id@icloud.com
MATCH_PASSWORD=guclu-sifre-buraya
# MATCH_GIT_BASIC_AUTHORIZATION=base64(user:token)  # HTTPS match reposu için

# App Store Connect API (deploy lane)
APPSTORE_KEY_ID=
APPSTORE_ISSUER_ID=
APPSTORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Play (deploy lane)
PLAY_STORE_JSON_PATH=/absolute/path/to/play-store-service-account.json
PLAY_STORE_TRACK=internal
